PORT=3000
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
AGENT_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-5-mini
# Reasoning effort: none, low, medium, high (default: low)
AGENT_LLM_REASONING_EFFORT=low
# Media generation — uses OpenAI by default (DALL-E / Sora)
# Set OPENAI_API_KEY or it falls back to AGENT_LLM_API_KEY
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_VIDEO_MODEL=sora

# Optional: custom media endpoint (overrides OpenAI if set)
MEDIA_GENERATION_ENDPOINT=

# Media storage directory (default: data/media)
MEDIA_STORAGE_DIR=

# Optional API keys for external sources (most work without keys)
NASA_API_KEY=DEMO_KEY
TMDB_API_KEY=
YOUTUBE_API_KEY=
ALPHA_VANTAGE_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
GUARDIAN_API_KEY=
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=
GIPHY_API_KEY=
GOOGLE_MAPS_API_KEY=

REDIS_URL=redis://127.0.0.1:6379
AGENT_RUN_CONCURRENCY=200
