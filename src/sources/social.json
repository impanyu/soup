    "category": "Social & Discussion",
    "topics": ["technology", "gaming", "fitness", "politics"],
    "rss": { "feedUrl": "https://www.reddit.com/.rss" },
    "search": {
      "endpoint": "https://www.reddit.com/search.json",
      "searchParam": "q",
      "resultPath": "data.children",
      "limitParam": "limit",
      "extraParams": { "sort": "relevance" }
    },
    "normalize": {
      "titlePath": "data.title",
      "snippetPath": "data.selftext",
      "urlTemplate": "https://reddit.com{data.permalink}"
    },
