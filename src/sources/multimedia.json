[
  {
    "id": "unsplash",
    "name": "Unsplash",
    "category": "Multimedia",
    "topics": [
      "photography",
      "art",
      "design",
      "travel"
    ],
    "siteUrl": "https://unsplash.com",
    "search": {
      "endpoint": "https://api.unsplash.com/search/photos",
      "searchParam": "query",
      "resultPath": "results",
      "limitParam": "per_page"
    },
    "normalize": {
      "titlePath": "description",
      "snippetTemplate": "Photo by {user.name} on Unsplash",
      "urlPath": "links.html"
    },
    "responseFormat": "json",
    "dataType": "media",
    "requiresKey": true,
    "envKey": "UNSPLASH_ACCESS_KEY"
  },
  {
    "id": "pexels",
    "name": "Pexels",
    "category": "Multimedia",
    "topics": [
      "photography",
      "art",
      "design"
    ],
    "siteUrl": "https://www.pexels.com",
    "search": {
      "endpoint": "https://api.pexels.com/v1/search",
      "searchParam": "query",
      "resultPath": "photos",
      "limitParam": "per_page"
    },
    "normalize": {
      "titlePath": "alt",
      "snippetTemplate": "Photo by {photographer}",
      "urlPath": "url"
    },
    "responseFormat": "json",
    "dataType": "media",
    "requiresKey": true,
    "envKey": "PEXELS_API_KEY"
  },
  {
    "id": "wikimedia-commons",
    "name": "Wikimedia Commons",
    "category": "Multimedia",
    "topics": [
      "photography",
      "history",
      "science",
      "education"
    ],
    "siteUrl": "https://commons.wikimedia.org",
    "search": {
      "endpoint": "https://commons.wikimedia.org/w/api.php",
      "searchParam": "gsrsearch",
      "resultPath": "query.pages",
      "limitParam": "gsrlimit",
      "extraParams": {
        "action": "query",
        "generator": "search",
        "gsrnamespace": "6",
        "prop": "imageinfo",
        "iiprop": "url|extmetadata",
        "format": "json",
        "origin": "*"
      }
    },
    "normalize": {
      "titlePath": "title",
      "snippetPath": "title",
      "urlTemplate": "https://commons.wikimedia.org/wiki/{title}"
    },
    "responseFormat": "json",
    "dataType": "media",
    "requiresKey": false,
    "envKey": null
  },
  {
    "id": "podcast-index",
    "name": "Podcast Index",
    "category": "Multimedia",
    "topics": [
      "podcasts",
      "music",
      "education",
      "technology"
    ],
    "siteUrl": "https://podcastindex.org",
    "search": {
      "endpoint": "https://api.podcastindex.org/api/1.0/search/byterm",
      "searchParam": "q",
      "resultPath": "feeds",
      "limitParam": "max"
    },
    "normalize": {
      "titlePath": "title",
      "snippetPath": "description",
      "urlPath": "link"
    },
    "responseFormat": "json",
    "dataType": "media",
    "requiresKey": true,
    "envKey": "PODCAST_INDEX_API_KEY"
  },
  {
    "id": "internet-archive",
    "name": "Internet Archive",
    "category": "Multimedia",
    "topics": [
      "books",
      "history",
      "music",
      "film",
      "education"
    ],
    "siteUrl": "https://archive.org",
    "search": {
      "endpoint": "https://archive.org/advancedsearch.php",
      "searchParam": "q",
      "resultPath": "response.docs",
      "limitParam": "rows",
      "extraParams": {
        "output": "json",
        "fl[]": "identifier,title,description,mediatype"
      }
    },
    "normalize": {
      "titlePath": "title",
      "snippetPath": "description",
      "urlTemplate": "https://archive.org/details/{identifier}"
    },
    "responseFormat": "json",
    "dataType": "media",
    "requiresKey": false,
    "envKey": null
  },
